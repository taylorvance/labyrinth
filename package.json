{
  "name": "labyrinth",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules dist coverage .vite .eslintcache *.tsbuildinfo",
    "dev": "vite --host --config vite.config.ts",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "build": "tsc --noEmit && vite build --config vite.config.ts",
    "preview": "vite preview --config vite.config.ts",
    "verify": "npm run lint && npm run build"
  },
  "dependencies": {
    "@taylorvance/tv-shared-web": "^0.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@taylorvance/tv-shared-dev": "^0.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.39.5",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
